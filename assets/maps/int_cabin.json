    {
     "id": 623,
     "name": "the campaign table",
     "type": "oddity",
     "x": 48,
     "y": 48,
     "width": 16,
     "height": 16,
     "properties": [
      {
       "name": "text",
       "type": "string",
       "value": "The table where a young Colonel Washington kept his headquarters in 1755, when this cabin stood inside Fort Cumberland and the fort still had a reason. The wood is scarred where a map was pinned and repinned. Someone keeps it dusted. Someone always has."
      }
     ]
    },
    {
     "id": 624,
     "name": "a musket ball in the sill",
     "type": "oddity",
     "x": 176,
     "y": 96,
     "width": 16,
     "height": 16,
     "properties": [
      {
       "name": "text",
       "type": "string",
       "value": "A lead ball buried in the window sill, French by its cast, left where it struck a hundred years ago. Children dare each other to touch it. The oldest say it is still warm, and the oldest are not always lying."
      }
     ]
    },
    {
     "id": 700,
     "name": "an oddity",
     "type": "oddity",
     "x": 32,
     "y": 112,
     "width": 32,
     "height": 16,
     "properties": [
      {
       "name": "text",
       "type": "string",
       "value": "A rope bed strung tight under a pieced quilt, the batting flat where the same body has lain for years."
      }
     ]
    },
    {
     "id": 701,
     "name": "an oddity",
     "type": "oddity",
     "x": 144,
     "y": 112,
     "width": 32,
     "height": 16,
     "properties": [
      {
       "name": "text",
       "type": "string",
       "value": "A plank table set for a meal that never quite happens, a candle guttered to a stub."
      }
     ]
    },
    {
     "id": 702,
     "name": "an oddity",
     "type": "oddity",
     "x": 176,
     "y": 48,
     "width": 16,
     "height": 16,
     "properties": [
      {
       "name": "text",
       "type": "string",
       "value": "A fieldstone hearth, the mortar packed with river clay and, if you look, one child's marble set in for luck."
      }
     ]
    },
    {
     "id": 703,
     "name": "an oddity",
     "type": "oddity",
     "x": 32,
     "y": 48,
     "width": 16,
     "height": 16,
     "properties": [
      {
       "name": "text",
       "type": "string",
       "value": "A writing desk gone amber with lamp smoke, the blotter a palimpsest of every letter this town confessed to paper."
      }
     ]
    },
    {
     "id": 704,
     "name": "an oddity",
